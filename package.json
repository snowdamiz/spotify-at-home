{
  "name": "tunely",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @tunely/shared && npm run build -w @tunely/api && npm run build -w @tunely/app",
    "dev:api": "npm run dev -w @tunely/api",
    "dev:app": "npm run web -w @tunely/app",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0",
    "vitest": "^3.1.2"
  }
}
