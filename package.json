{
  "name": "broadside",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @broadside/shared && npm run build -w @broadside/api && npm run build -w @broadside/client",
    "dev": "concurrently -n api,client -c blue,green \"npm run dev:api\" \"npm run dev:client\"",
    "dev:api": "npm run dev -w @broadside/api",
    "dev:client": "npm run dev -w @broadside/client",
    "dev:kill": "node scripts/kill-dev-servers.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -b && npm run typecheck -w @broadside/client"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0",
    "vitest": "^3.1.2"
  }
}
