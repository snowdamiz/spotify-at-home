{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "@tunely/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@tunely/shared/*": [
        "../../packages/shared/src/*"
      ],
      "@tunely/app/*": [
        "./src/*"
      ]
    },
    "strict": true,
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo"
  },
  "include": [
    "app/**/*.tsx",
    "src/**/*.tsx",
    "test/**/*.ts"
  ],
  "references": [
    {
      "path": "../../packages/shared"
    }
  ]
}
