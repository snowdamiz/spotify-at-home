{
  "name": "@broadside/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1038.0",
    "dotenv": "16.4.7",
    "fastify": "^5.3.2",
    "youtube-dl-exec": "3.1.5"
  },
  "devDependencies": {
    "tsx": "^4.19.4"
  }
}
