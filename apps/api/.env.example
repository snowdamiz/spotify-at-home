PORT=3101
HOST=0.0.0.0
APP_WEB_ORIGIN=http://localhost:8082
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3101/api/auth/google/callback
ADMIN=admin@example.com
BROADSIDE_ADMIN_USER_EMAILS=admin@example.com
BROADSIDE_DATABASE_PATH=../../data/broadside.sqlite
BROADSIDE_AUDIO_STORAGE_PATH=../../data/audio
# Imported tracks are normalized before storage using ffmpeg loudnorm.
BROADSIDE_AUDIO_NORMALIZATION_ENABLED=true
BROADSIDE_AUDIO_NORMALIZATION_MODE=two-pass
BROADSIDE_AUDIO_NORMALIZATION_TARGET_LUFS=-16
BROADSIDE_AUDIO_NORMALIZATION_TRUE_PEAK=-1.5
BROADSIDE_AUDIO_NORMALIZATION_LRA=11
BROADSIDE_AUDIO_NORMALIZATION_BITRATE=192k
# Set to r2 in production so audio goes to Cloudflare R2 instead of local disk.
BROADSIDE_AUDIO_STORAGE_DRIVER=local
R2_ACCOUNT_ID=replace-with-cloudflare-account-id
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
R2_BUCKET=replace-with-r2-bucket-name
R2_KEY_PREFIX=broadside/audio
